.{
    .name = .__NAME__,
    .version = "0.1.0",
    .minimum_zig_version = "0.16.0",
    // `zigbind new` fills in `.fingerprint` and adds the `zigbind` dependency
    // below via `zig fetch --save` (which pins zigbind by content hash).
    .dependencies = .{},
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src",
    },
}
